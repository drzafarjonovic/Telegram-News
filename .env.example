# ============================================================
#  Telegram-News bot — sozlamalar namunasi
#  Bu faylni `.env` deb nusxalang va qiymatlarni to'ldiring:
#    cp .env.example .env
#  Railway'da esa bularni "Variables" bo'limiga qo'shasiz.
# ============================================================

# ---------- 1) BOT (foydalanuvchilar bilan muloqot) ----------
# @BotFather dan oling: https://t.me/BotFather  ->  /newbot
BOT_TOKEN=123456:ABC-DEF_your_bot_token_here

# Admin Telegram ID'lari (vergul bilan), masalan: 111111111,222222222
# O'z ID'ngizni @userinfobot dan bilib oling.
ADMIN_IDS=111111111

# ---------- 2) USERBOT (kanallarni o'qiydigan shaxsiy akkaunt) ----------
# https://my.telegram.org -> API development tools dan oling
API_ID=1234567
API_HASH=your_api_hash_here

# Telethon StringSession (login.py skripti orqali bir marta yarating).
# Bo'sh qoldirsangiz, birinchi ishga tushirishda telefon raqami so'raladi
# (Railway'da bu ishlamaydi — STRING_SESSION'ni oldindan to'ldiring).
STRING_SESSION=

# ---------- 3) MA'LUMOTLAR BAZASI (Supabase / Postgres) ----------
# Supabase -> Project Settings -> Database -> Connection string (URI).
# Railway uchun "Connection pooling" (port 6543) tavsiya etiladi.
# Namuna: postgresql://postgres:[PAROL]@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# Postgres schema nomi. Bot barcha jadvallarini shu schema ichida yaratadi,
# shuning uchun bitta Supabase bazasini boshqa loyiha bilan baham ko'rish XAVFSIZ.
# (O'zgartirish shart emas — standart 'tgnews' qoldiring.)
DB_SCHEMA=tgnews

# ---------- 4) AI PROVAYDER ----------
# Asosiy provayder: groq | openai | gemini
AI_PROVIDER=groq

# Asosiy provayderning API kaliti:
#   groq   -> https://console.groq.com/keys       (BEPUL)
#   openai -> https://platform.openai.com/api-keys
#   gemini -> https://aistudio.google.com/apikey   (BEPUL)
AI_API_KEY=your_ai_api_key_here

# Model nomi (bo'sh qoldirsangiz provayderga mos standart model ishlatiladi):
#   groq   -> llama-3.3-70b-versatile
#   openai -> gpt-4o-mini
#   gemini -> gemini-2.0-flash
AI_MODEL=

# --- AI Fallback (zaxira) ---
# Asosiy provayder ishlamasa, shu tartibda navbatdagisiga avtomatik o'tadi.
# Vergul bilan, masalan: gemini,openai
AI_FALLBACKS=

# Fallback provayderlar uchun alohida kalitlar (kerakli bo'lganini to'ldiring):
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# ---------- 5) TAHLIL SOZLAMALARI ----------
# Tahlil natijasi tili: uz | ru | en
ANALYSIS_LANGUAGE=uz

# ---------- 6) BOSHQA ----------
# Standart vaqt mintaqasi
TIMEZONE=Asia/Tashkent

# Bir foydalanuvchi kuzata oladigan maksimal kanallar soni (global standart)
MAX_CHANNELS_PER_USER=10

# Bitta AI chaqiruviga jo'natiladigan maksimal post soni (chunking uchun)
MAX_POSTS_PER_CHUNK=40

# --- Cache pipeline / dedup ---
# Dublikat aniqlash chegarasi: Jaccard o'xshashligi (0..1). Kattaroq = qattiqroq.
# 0.5 = so'zlarning yarmi mos kelsa, bir xil yangilik deb hisoblanadi.
DEDUP_SIMILARITY=0.5

# Har bir tahlil siklida nechta post qayta ishlanadi (Groq rate-limitdan saqlanish)
PROCESS_BATCH_SIZE=25

# ============================================================
#  ENTERPRISE v2.0 sozlamalari (barchasi ixtiyoriy — defolt qiymatlar bor)
# ============================================================

# --- Ingest pipeline (navbat + workerlar) ---
INGEST_WORKERS=4              # parallel qayta ishlovchi worker soni
INGEST_QUEUE_MAX=5000         # navbatning maksimal uzunligi (backpressure)
STORE_RAW_MESSAGES=true       # har xabarning xom JSON nusxasini raw_messages'ga saqlash

# --- Backfill (bo'shliqlarni to'ldirish, GetHistory) ---
BACKFILL_ENABLED=true
BACKFILL_LIMIT=100            # YANGI kanal uchun: dastlab olinadigan so'nggi postlar soni
BACKFILL_INTERVAL_MIN=60      # davriy backfill oralig'i (daqiqa)
# Mavjud kanaldagi bo'shliqni to'ldirishda bir siklda maks xabar.
# 0 = cheksiz (bo'shliq to'liq to'ldiriladi). Runaway'dan qo'rqsangiz: masalan 5000.
BACKFILL_MAX_TOTAL=0

# --- OCR (rasmdan matn) — TO'LIQ QAMROV uchun yoqilgan ---
# Captionsiz rasm/media ichidagi yozuvni matnga aylantiradi (tesseract kerak).
OCR_ENABLED=true
OCR_LANGS=uzb+rus+eng        # tesseract til paketlari (Dockerfile'da o'rnatiladi)

# --- Speech-to-Text (Whisper) — TO'LIQ QAMROV uchun yoqilgan ---
# Ovoz/audio/video/video_note/gif xabarlarni nutqdan matnga aylantiradi.
# Groq bepul Whisper beradi (STT_API_KEY bo'sh bo'lsa AI_API_KEY ishlatiladi):
STT_ENABLED=true
STT_API_KEY=                 # bo'sh bo'lsa AI_API_KEY (masalan Groq kaliti)
STT_BASE_URL=https://api.groq.com/openai/v1   # OpenAI-compatible endpoint
STT_MODEL=whisper-large-v3   # Groq: whisper-large-v3 | OpenAI: whisper-1
MEDIA_DOWNLOAD_MAX_MB=20      # OCR/STT uchun yuklab olinadigan media hajm chegarasi (MB)

# --- Monitoring (Prometheus metrikslari) ---
METRICS_ENABLED=true
METRICS_PORT=9101            # /metrics va /healthz shu portda
